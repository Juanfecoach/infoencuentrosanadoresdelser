# ─── Supabase ──────────────────────────────────────────────────────────────
# URL del proyecto Supabase
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
VITE_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"

# Clave pública (anon key) — segura para el cliente
SUPABASE_PUBLISHABLE_KEY="eyJ..."
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ..."
VITE_SUPABASE_PROJECT_ID="xxxxxxxxxxxx"

# Clave de servicio (service_role) — SOLO en el servidor, NUNCA en el cliente
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── Sesión ────────────────────────────────────────────────────────────────
# Secreto de al menos 32 caracteres para firmar las cookies de sesión
SESSION_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio-de-32-chars"

# ─── Gemini AI (asistente Pera) ────────────────────────────────────────────
GEMINI_API_KEY="AIza..."
